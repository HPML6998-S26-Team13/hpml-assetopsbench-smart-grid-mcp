# Experiment 2 follow-on ablation - Z + Self-Ask + D.
#
# This stacks the strongest PE-family orchestration variant currently in the
# repo with the Cell D serving/transport stack:
#   - Verified PE with Self-Ask enabled
#   - optimized MCP connection reuse for repo-local PE-family runners
#   - vLLM prefix caching
#   - compressed-tensors W8A8 INT8 checkpoint
#   - BF16 model dtype plus fp8 KV cache
#
# Treat as an exploratory "best engineered PE-family" ceiling, not as a core
# Experiment 2 cell unless the intermediate ladder stays easy to explain.

EXPERIMENT_NAME="exp2_cell_ZSD_verified_pe_self_ask_mcp_model_optimized"
EXPERIMENT_CELL="ZSD"
EXPERIMENT_FAMILY="exp2_orchestration_ablation"
SCENARIO_SET_NAME="smartgrid_multi_domain"
SCENARIOS_GLOB="data/scenarios/multi_*.json"

MODEL_ID="openai/Llama-3.1-8B-Instruct-int8"

ORCHESTRATION="verified_pe"
MCP_MODE="optimized"
TRIALS=3
ENABLE_SELF_ASK=1
ENABLE_SMARTGRID_SERVERS=1
CONTRIBUTING_EXPERIMENTS="exp2_orchestration_ablation"
SCENARIO_DOMAIN_SCOPE="multi_domain"

MODEL_PROVIDER="vllm"
SERVING_STACK="insomnia_vllm"
QUANTIZATION_MODE="compressed-tensors-int8-bf16-fp8kv"
# Keep this first ZSD run aligned with the proven Cell D INT8 path.
# If the PE-family prompts need more room, rerun at 16384/32768.
MAX_MODEL_LEN=8192
TEMPERATURE=0.0
# The INT8 exploratory profile uses MAX_MODEL_LEN=8192. Cap PE-family
# intermediate generations so verifier/replan prompts do not cross the local
# context window by a handful of tokens.
MAX_TOKENS=1024
JUDGE_MODEL=""

LAUNCH_VLLM=1
VLLM_MODEL_PATH="models/Llama-3.1-8B-Instruct-int8"
VLLM_SERVED_MODEL_NAME="Llama-3.1-8B-Instruct-int8"
VLLM_DTYPE="bfloat16"
VLLM_PORT=8000
VLLM_STARTUP_TIMEOUT=1200

# Model-side optimization knobs (#29 + #30 follow-on).
EXTRA_VLLM_ARGS="--quantization compressed-tensors --kv-cache-dtype fp8 --enable-prefix-caching"

ENABLE_WANDB=1
WANDB_ENTITY="assetopsbench-smartgrid"
WANDB_PROJECT="assetopsbench-smartgrid"
WANDB_MODE="online"

# Optimized MCP launch: reuse initialized MCP sessions inside each PE-family
# scenario run rather than reopening stdio for descriptions and every tool call.
AAT_MCP_SERVER_LAUNCH_MODE="python"
AAT_MCP_CLIENT_TIMEOUT_SECONDS=120

# Torch profiler: captures one replay pass per run while vLLM is still live.
TORCH_PROFILE="${TORCH_PROFILE:-1}"
