# Experiment 2 - Cell Z
# Optional Verified PE follow-on only; keep out of the core committed grid
# unless the runner becomes real enough to benchmark. The runtime hook still
# uses the legacy `hybrid` label today.

EXPERIMENT_NAME="exp2_cell_Z_hybrid_mcp_baseline"
EXPERIMENT_CELL="Z"
EXPERIMENT_FAMILY="exp2_orchestration"
SCENARIO_SET_NAME="smartgrid_multi_domain_v1"
SCENARIOS_GLOB="data/scenarios/multi_*.json"

MODEL_ID="openai/Llama-3.1-8B-Instruct"

ORCHESTRATION="hybrid"
MCP_MODE="baseline"
TRIALS=5
ENABLE_SMARTGRID_SERVERS=1
CONTRIBUTING_EXPERIMENTS="exp2_orchestration"
SCENARIO_DOMAIN_SCOPE="multi_domain"

MODEL_PROVIDER="vllm"
SERVING_STACK="insomnia_vllm"
QUANTIZATION_MODE="fp16"
MAX_MODEL_LEN=32768
TEMPERATURE=0.0
MAX_TOKENS=0
JUDGE_MODEL=""

LAUNCH_VLLM=1
VLLM_MODEL_PATH="models/Llama-3.1-8B-Instruct"
VLLM_PORT=8000

ENABLE_WANDB=1
WANDB_ENTITY="assetopsbench-smartgrid"
WANDB_PROJECT="assetopsbench-smartgrid"
WANDB_MODE="online"

HYBRID_RUNNER_TEMPLATE='cd "$AOB_PATH" && echo "TODO: wire canonical Verified PE runner for Cell Z" >&2 && exit 1'
