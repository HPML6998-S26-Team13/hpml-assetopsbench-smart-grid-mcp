# Benchmark config for issue #3: prove the evaluation harness runs on canonical main.
#
# This is a committed, reproducible config — not a temp file.
# Runs a single non-Smart-Grid FMSR scenario (AOB-FMSR-001) through the
# plan-execute harness using our Smart Grid MCP servers and WatsonX.
#
# No Docker required: the FMSR server reads only failure_modes.csv (no CouchDB).
#
# Usage (dry-run to validate wiring):
#   DRY_RUN=1 bash scripts/run_experiment.sh configs/issue3_aob_harness_smoke.env
#
# Usage (actual run — requires WATSONX_APIKEY and WATSONX_PROJECT_ID in .env or shell):
#   bash scripts/run_experiment.sh configs/issue3_aob_harness_smoke.env
#
# After a successful run, commit the generated artifacts under:
#   benchmarks/cell_Y_plan_execute/raw/<run-id>/
#   benchmarks/cell_Y_plan_execute/config.json
#   benchmarks/cell_Y_plan_execute/summary.json

# --- Required benchmark identity ---
EXPERIMENT_NAME="issue3_aob_fmsr_harness_smoke"
EXPERIMENT_CELL="Y"
EXPERIMENT_FAMILY="exp2_orchestration"
SCENARIO_SET_NAME="aob_fmsr_catalog_smoke"
SCENARIOS_GLOB="data/scenarios/aob_fmsr_01_list_failure_modes.json"

# --- Model (WatsonX, no local GPU required) ---
MODEL_ID="watsonx/meta-llama/llama-3-3-70b-instruct"

# --- Experiment condition ---
ORCHESTRATION="plan_execute"
MCP_MODE="baseline"
TRIALS=1
ENABLE_SMARTGRID_SERVERS=1
CONTRIBUTING_EXPERIMENTS=""
SCENARIO_DOMAIN_SCOPE="single_domain"

# --- Model / serving metadata ---
MODEL_PROVIDER="watsonx"
SERVING_STACK="watsonx"
QUANTIZATION_MODE="provider_managed"
MAX_MODEL_LEN=8192
TEMPERATURE=0.0
MAX_TOKENS=0
JUDGE_MODEL=""

# --- Local vLLM: disabled (using WatsonX) ---
LAUNCH_VLLM=0

# --- WandB ---
ENABLE_WANDB=0
WANDB_ENTITY="assetopsbench-smartgrid"
WANDB_PROJECT="assetopsbench-smartgrid"
WANDB_MODE="offline"
