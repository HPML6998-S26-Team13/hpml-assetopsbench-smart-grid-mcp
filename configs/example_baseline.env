# Example experiment config for scripts/run_experiment.sh
# Sourced as bash; quote any values with whitespace.
#
# Usage:
#   sbatch scripts/run_experiment.sh configs/example_baseline.env

# --- Required ---

# Human-readable cell name; appears in run IDs and meta.json
EXPERIMENT_NAME="aat_mcp_baseline"

# Glob of scenario files to run (relative to repo root)
SCENARIOS_GLOB="data/scenarios/iot_*.json"

# Harness model ID, format <provider>/<model>.
# - WatsonX: watsonx/meta-llama/llama-3-3-70b-instruct
# - Local vLLM (this repo's primary path): openai/Llama-3.1-8B-Instruct
#   (When LAUNCH_VLLM=1, the script sets OPENAI_API_BASE so the harness
#    routes to our local server. Verify with Akshat that plan-execute's
#    openai/* path honors OPENAI_API_BASE.)
MODEL_ID="openai/Llama-3.1-8B-Instruct"

# --- Optional (defaults shown) ---

# Orchestration: plan_execute | agent_as_tool | hybrid
# (TODO: wire to harness flag once Alex's AaT/PE/Hybrid implementations land)
ORCHESTRATION="plan_execute"

# MCP mode: baseline | optimized | direct
# baseline  = Tanisha's hardened MCP servers, default config
# optimized = same servers, batched + connection-reused (W4 work)
# direct    = no MCP, harness uses in-process AssetOpsBench tools
MCP_MODE="baseline"

# Number of trials per scenario (used for variance estimation)
TRIALS=1

# vLLM launch knobs
LAUNCH_VLLM=1
VLLM_MODEL_PATH="models/Llama-3.1-8B-Instruct"
VLLM_PORT=8000
MAX_MODEL_LEN=8192

# Path to the AssetOpsBench checkout (sibling repo by default)
# AOB_PATH="$REPO_ROOT/../AssetOpsBench"
