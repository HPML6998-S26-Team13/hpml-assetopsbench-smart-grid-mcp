# Experiment 1 - Cell A
# Direct-tool baseline without MCP servers in the loop.

EXPERIMENT_NAME="exp1_cell_A_direct"
EXPERIMENT_CELL="A"
EXPERIMENT_FAMILY="exp1_mcp_overhead"
SCENARIO_SET_NAME="smartgrid_multi_domain_v1"
SCENARIOS_GLOB="data/scenarios/multi_*.json"

MODEL_ID="openai/Llama-3.1-8B-Instruct"

ORCHESTRATION="agent_as_tool"
MCP_MODE="direct"
TRIALS=5
ENABLE_SMARTGRID_SERVERS=0
CONTRIBUTING_EXPERIMENTS="exp1_mcp_overhead"
SCENARIO_DOMAIN_SCOPE="multi_domain"

MODEL_PROVIDER="vllm"
SERVING_STACK="insomnia_vllm"
QUANTIZATION_MODE="fp16"
MAX_MODEL_LEN=32768
TEMPERATURE=0.0
MAX_TOKENS=0
JUDGE_MODEL=""

LAUNCH_VLLM=1
VLLM_MODEL_PATH="models/Llama-3.1-8B-Instruct"
VLLM_PORT=8000

ENABLE_WANDB=1
WANDB_ENTITY="assetopsbench-smartgrid"
WANDB_PROJECT="assetopsbench-smartgrid"
WANDB_MODE="online"

# Required until a stable upstream AaT CLI lands.
AAT_RUNNER_TEMPLATE='cd "$AOB_PATH" && echo "TODO: wire canonical AaT runner for Cell A" >&2 && exit 1'
