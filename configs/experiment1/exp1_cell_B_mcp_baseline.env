# Experiment 1 - Cell B
# Shared MCP-baseline cell used by both Experiment 1 and Experiment 2.

EXPERIMENT_NAME="exp1_cell_B_mcp_baseline"
EXPERIMENT_CELL="B"
EXPERIMENT_FAMILY="exp1_mcp_overhead"
SCENARIO_SET_NAME="smartgrid_multi_domain_v1"
SCENARIOS_GLOB="data/scenarios/multi_*.json"

MODEL_ID="openai/Llama-3.1-8B-Instruct"

ORCHESTRATION="agent_as_tool"
MCP_MODE="baseline"
TRIALS=5
ENABLE_SMARTGRID_SERVERS=1
CONTRIBUTING_EXPERIMENTS="exp1_mcp_overhead,exp2_orchestration"
SCENARIO_DOMAIN_SCOPE="multi_domain"

MODEL_PROVIDER="vllm"
SERVING_STACK="insomnia_vllm"
QUANTIZATION_MODE="fp16"
MAX_MODEL_LEN=32768
TEMPERATURE=0.0
MAX_TOKENS=0
JUDGE_MODEL=""

LAUNCH_VLLM=1
VLLM_MODEL_PATH="models/Llama-3.1-8B-Instruct"
VLLM_PORT=8000

ENABLE_WANDB=1
WANDB_ENTITY="assetopsbench-smartgrid"
WANDB_PROJECT="assetopsbench-smartgrid"
WANDB_MODE="online"

AAT_RUNNER_TEMPLATE='cd "$AOB_PATH" && echo "TODO: wire canonical AaT runner for Cell B" >&2 && exit 1'
