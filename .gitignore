# Data (large files -- track with git-lfs or download separately)
data/raw/
*.csv
*.parquet
*.jsonl
!data/processed/*.csv
!results/metrics/**/*.csv
results/metrics/*.preflight.csv
!results/metrics/*.jsonl
# Per-trial latency records are part of the canonical Notebook 02 input
# (run_experiment.sh writes them via the benchmark trial loop). Keep them
# tracked so reviewers can replay analysis without cluster access.
!benchmarks/**/latencies.jsonl

# Slurm logs
logs/*.out

# Models (large, downloaded on cluster)
models/

